# --- Application Environment ---
APP_NAME="Cheryne's"
APP_ENV=local
APP_DEBUG=true
APP_URL=https://cherynes.example
APP_TIMEZONE=Africa/Nairobi

# --- Secure PostgreSQL Connection ---
DB_DSN=pgsql:host=localhost;port=5432;dbname=cherynes
DB_USER=your_secure_postgres_username
DB_PASS=your_strong_postgres_password

# --- Cleaned & Generative Session Setup ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_SECURE=false

# --- Payment Gateways (Keep Secrets Empty Until Production) ---
STRIPE_SECRET=
STRIPE_PUBLISHABLE=
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=https://cherynes.example

# --- Third-Party Integrations ---
GOOGLE_MAPS_API_KEY=

# --- System Admin Setup ---
ADMIN_EMAIL=admin@cherynes.com
# DO NOT STORE PLAIN TEXT ADMIN PASSWORDS HERE