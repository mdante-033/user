{
  "name": "cherynes/restaurant-app",
  "description": "Cheryne's restaurant ordering, reservations, payments, and admin web app.",
  "type": "project",
  "require": {
    "php": "^8.2",
    "stripe/stripe-php": "^20.0",
    "twbs/bootstrap": "5.3.8",
    "vlucas/phpdotenv": "^5.6"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "scripts": {
    "test": "phpunit"
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {}
  }
}
